{
  "version": 2,
  "builds": [
    {
      "src": "soundverseFrontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "soundverseBackend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "soundverseBackend/index.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/soundverseFrontend/static/$1"
    },
    {
      "src": "/asset-manifest.json",
      "dest": "/soundverseFrontend/asset-manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/soundverseFrontend/favicon.ico"
    },
    {
      "src": "/manifest.json",
      "dest": "/soundverseFrontend/manifest.json"
    },
    {
      "src": "/robots.txt",
      "dest": "/soundverseFrontend/robots.txt"
    },
    {
      "src": "/logo192.png",
      "dest": "/soundverseFrontend/logo192.png"
    },
    {
      "src": "/logo512.png",
      "dest": "/soundverseFrontend/logo512.png"
    },
    {
      "src": "/(.*)",
      "dest": "/soundverseFrontend/index.html"
    }
  ]
}
